{
  "name": "phase11-group-invite",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer token on group invite",
      "method": "POST",
      "path": "/group/invite",
      "body": "{\"device_id\":\"device-1\",\"username\":\"Alice\",\"group_name\":\"客户群\"}"
    },
    {
      "name": "invalid bearer token on group invite",
      "method": "POST",
      "path": "/group/invite",
      "headers": {
        "Authorization": "Bearer invalid.group.invite"
      },
      "body": "{\"device_id\":\"device-1\",\"username\":\"Alice\",\"group_name\":\"客户群\"}"
    }
  ]
}
