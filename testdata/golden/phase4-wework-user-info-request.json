{
  "name": "phase4-wework-user-info-request",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer on wework user info request",
      "method": "POST",
      "path": "/wework/user-info/request",
      "body": "{\"device_id\":\"device-1\"}"
    },
    {
      "name": "invalid bearer on wework user info request",
      "method": "POST",
      "path": "/wework/user-info/request",
      "headers": {
        "Authorization": "Bearer invalid.wework.user.info.request"
      },
      "body": "{\"device_id\":\"device-1\"}"
    }
  ]
}
