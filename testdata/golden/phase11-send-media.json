{
  "name": "phase11-send-media",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer token on send image",
      "method": "POST",
      "path": "/send/image"
    },
    {
      "name": "invalid bearer token on send image",
      "method": "POST",
      "path": "/send/image",
      "headers": {
        "Authorization": "Bearer invalid.send.image"
      }
    },
    {
      "name": "missing bearer token on send video",
      "method": "POST",
      "path": "/send/video"
    },
    {
      "name": "invalid bearer token on send video",
      "method": "POST",
      "path": "/send/video",
      "headers": {
        "Authorization": "Bearer invalid.send.video"
      }
    },
    {
      "name": "missing bearer token on send voice",
      "method": "POST",
      "path": "/send/voice"
    },
    {
      "name": "invalid bearer token on send voice",
      "method": "POST",
      "path": "/send/voice",
      "headers": {
        "Authorization": "Bearer invalid.send.voice"
      }
    },
    {
      "name": "missing bearer token on send file",
      "method": "POST",
      "path": "/send/file"
    },
    {
      "name": "invalid bearer token on send file",
      "method": "POST",
      "path": "/send/file",
      "headers": {
        "Authorization": "Bearer invalid.send.file"
      }
    }
  ]
}
