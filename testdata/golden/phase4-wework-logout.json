{
  "name": "phase4-wework-logout",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer on wework logout",
      "method": "POST",
      "path": "/wework/logout",
      "body": "{\"device_id\":\"device-1\"}"
    },
    {
      "name": "invalid bearer on wework logout",
      "method": "POST",
      "path": "/wework/logout",
      "headers": {
        "Authorization": "Bearer invalid.wework.logout"
      },
      "body": "{\"device_id\":\"device-1\"}"
    }
  ]
}
