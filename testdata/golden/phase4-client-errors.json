{
  "name": "phase4-client-errors",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "runtime error report with operator hint",
      "method": "POST",
      "path": "/api/v1/client-errors",
      "body": "{\"source\":\"admin-web\",\"category\":\"runtime\",\"message\":\"页面渲染失败\",\"detail\":\"component mount failed\",\"path\":\"/admin\",\"page_url\":\"https://cloud.example/admin\",\"component\":\"AdminApp\",\"operator_hint\":\"admin-001\",\"meta\":{\"route\":\"/admin\"}}"
    },
    {
      "name": "ignored no account empty-state noise",
      "method": "POST",
      "path": "/api/v1/client-errors",
      "body": "{\"message\":\"当前客服没有可用账号，无法初始化会话工作台\",\"detail\":\"ChatLayout missing default account\"}"
    },
    {
      "name": "missing message validation",
      "method": "POST",
      "path": "/api/v1/client-errors",
      "body": "{\"source\":\"web\"}"
    },
    {
      "name": "batch client logs report",
      "method": "POST",
      "path": "/api/v1/client-logs",
      "headers": {
        "X-Forwarded-For": "203.0.113.10, 192.0.2.10"
      },
      "body": "{\"logs\":[{\"ts\":\"2026-06-29T09:30:00Z\",\"level\":\"ERROR\",\"module\":\"runtime\",\"action\":\"window.onerror\",\"detail\":\"页面运行错误\",\"trace_id\":\"trace-client-log-1\",\"extra\":{\"category\":\"runtime\",\"component\":\"Workbench\"}}]}"
    },
    {
      "name": "client logs must be list",
      "method": "POST",
      "path": "/api/v1/client-logs",
      "body": "{\"logs\":{}}"
    }
  ]
}
