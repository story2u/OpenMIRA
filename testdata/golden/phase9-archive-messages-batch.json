{
  "name": "phase9-archive-messages-batch",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "archive messages batch missing auth",
      "method": "POST",
      "path": "/api/v1/archive/messages/batch",
      "body": "{\"enterprise_id\":\"ent-1\",\"source\":\"self_decrypt\",\"messages\":[]}"
    },
    {
      "name": "archive messages batch invalid agent token",
      "method": "POST",
      "path": "/api/v1/archive/messages/batch",
      "headers": {
        "X-Agent-Token": "wrong-token"
      },
      "body": "{\"enterprise_id\":\"ent-1\",\"source\":\"self_decrypt\",\"messages\":[{\"archive_msgid\":\"am-1\",\"sender_id\":\"user-1\",\"content\":\"hello\"}]}"
    },
    {
      "name": "archive messages batch valid agent token",
      "method": "POST",
      "path": "/api/v1/archive/messages/batch",
      "headers": {
        "X-Agent-Token": "agent-token"
      },
      "body": "{\"enterprise_id\":\"ent-1\",\"source\":\"self_decrypt\",\"cursor\":\"42\",\"messages\":[{\"archive_msgid\":\"am-1\",\"sender_id\":\"wm_external_001\",\"content\":\"hello\",\"msg_type\":\"text\",\"direction\":\"incoming\"}]}"
    },
    {
      "name": "archive messages batch invalid json",
      "method": "POST",
      "path": "/api/v1/archive/messages/batch",
      "headers": {
        "Authorization": "Bearer test-token"
      },
      "body": "{"
    }
  ]
}
