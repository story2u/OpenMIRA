{
  "name": "phase4-wework-user-info-candidates",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer on user info candidates",
      "method": "GET",
      "path": "/wework/user-info/candidates?device_id=device-1"
    },
    {
      "name": "invalid bearer on user info candidates",
      "method": "GET",
      "path": "/wework/user-info/candidates?device_id=device-1",
      "headers": {
        "Authorization": "Bearer invalid.wework.user.info.candidates"
      }
    }
  ]
}
