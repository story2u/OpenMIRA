{
  "name": "phase11-send-text",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer token on send text",
      "method": "POST",
      "path": "/send/text",
      "body": "{\"device_id\":\"device-1\",\"username\":\"Alice\",\"target_username\":\"Bob\",\"message\":\"hello\"}"
    },
    {
      "name": "invalid bearer token on send text",
      "method": "POST",
      "path": "/send/text",
      "headers": {
        "Authorization": "Bearer invalid.send.text"
      },
      "body": "{\"device_id\":\"device-1\",\"username\":\"Alice\",\"target_username\":\"Bob\",\"message\":\"hello\"}"
    }
  ]
}
