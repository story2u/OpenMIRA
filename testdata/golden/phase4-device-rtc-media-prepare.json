{
  "name": "phase4-device-rtc-media-prepare",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer token on media prepare",
      "method": "POST",
      "path": "/api/v1/devices/device-1/media/start",
      "body": "{\"participant_identity\":\"user-device-1\",\"activate\":false}"
    },
    {
      "name": "missing bearer token on camera stream configure",
      "method": "POST",
      "path": "/api/v1/devices/device-1/media/camera-stream",
      "body": "{\"addr\":\"webrtc://relay/live/slot-18\"}"
    },
    {
      "name": "missing bearer token on camera stream stop",
      "method": "DELETE",
      "path": "/api/v1/devices/device-1/media/camera-stream"
    },
    {
      "name": "missing bearer token on audio playback",
      "method": "POST",
      "path": "/api/v1/devices/device-1/media/audio",
      "body": "{\"path\":\"/sdcard/input.wav\"}"
    },
    {
      "name": "missing bearer token on media stop",
      "method": "POST",
      "path": "/api/v1/devices/device-1/media/stop",
      "body": "{\"participant_identity\":\"user-device-1\"}"
    }
  ]
}
