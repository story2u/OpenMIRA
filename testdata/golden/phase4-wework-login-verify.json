{
  "name": "phase4-wework-login-verify",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576
  },
  "cases": [
    {
      "name": "missing bearer on wework login verify",
      "method": "POST",
      "path": "/wework/login/verify-code",
      "body": "{\"device_id\":\"device-1\",\"verify_code\":\"123456\"}"
    },
    {
      "name": "invalid bearer on wework login verify",
      "method": "POST",
      "path": "/wework/login/verify-code",
      "headers": {
        "Authorization": "Bearer invalid.wework.login.verify"
      },
      "body": "{\"device_id\":\"device-1\",\"verify_code\":\"123456\"}"
    }
  ]
}
