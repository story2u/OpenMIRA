{
  "name": "phase2-session-cs-login",
  "options": {
    "timeout_ms": 5000,
    "max_body_bytes": 1048576,
    "ignore_json_fields": ["token", "expires_at"]
  },
  "cases": [
    {
      "name": "missing credentials",
      "method": "POST",
      "path": "/api/v1/session/cs-login",
      "body": "{}"
    },
    {
      "name": "invalid password",
      "method": "POST",
      "path": "/api/v1/session/cs-login",
      "body": "{\"assignee_id\":\"cs-001\",\"password\":\"wrong\"}"
    },
    {
      "name": "successful cs login",
      "method": "POST",
      "path": "/api/v1/session/cs-login",
      "body": "{\"assignee_id\":\"cs-001\",\"password\":\"secret\"}"
    }
  ]
}
