  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "export:ios": "expo export --platform ios --output-dir dist/ios",
    "export:android": "expo export --platform android --output-dir dist/android",
    "fixture:sse": "node scripts/sse-fixture.mjs",
    "fixture:auth": "node scripts/auth-fixture.mjs",
    "prebuild": "expo prebuild",
    "android:release": "expo run:android --variant release",
    "ios:release": "expo run:ios --configuration Release"
  },
  "private": true
