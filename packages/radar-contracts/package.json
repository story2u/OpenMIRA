{
  "name": "@story2u/radar-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./analysis-runs": {
      "types": "./src/analysis-runs.ts",
      "default": "./src/analysis-runs.ts"
    },
    "./auth": {
      "types": "./src/auth.ts",
      "default": "./src/auth.ts"
    },
    "./devices": {
      "types": "./src/devices.ts",
      "default": "./src/devices.ts"
    },
    "./interactive-agent": {
      "types": "./src/interactive-agent.ts",
      "default": "./src/interactive-agent.ts"
    },
    "./openapi": {
      "types": "./src/openapi.ts",
      "default": "./src/openapi.ts"
    },
    "./opportunities": {
      "types": "./src/opportunities.ts",
      "default": "./src/opportunities.ts"
    },
    "./messages": {
      "types": "./src/messages.ts",
      "default": "./src/messages.ts"
    },
    "./opportunity-actions": {
      "types": "./src/opportunity-actions.ts",
      "default": "./src/opportunity-actions.ts"
    },
    "./templates": {
      "types": "./src/templates.ts",
      "default": "./src/templates.ts"
    },
    "./settings": {
      "types": "./src/settings.ts",
      "default": "./src/settings.ts"
    },
    "./telegram": {
      "types": "./src/telegram.ts",
      "default": "./src/telegram.ts"
    },
    "./subscriptions": {
      "types": "./src/subscriptions.ts",
      "default": "./src/subscriptions.ts"
    },
    "./sync": {
      "types": "./src/sync.ts",
      "default": "./src/sync.ts"
    }
  },
  "scripts": {
    "generate": "openapi-typescript openapi.json -o src/openapi.ts",
    "check:generated": "openapi-typescript openapi.json -o .generated/openapi.ts && node scripts/assert-generated.mjs",
    "typecheck": "tsc --noEmit",
    "check": "pnpm check:generated && pnpm typecheck"
  },
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "typescript": "5.7.3"
  }
}
