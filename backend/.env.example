# Local development defaults. Production .env is generated by GitHub Actions
# from repository/environment vars and secrets.
DATABASE_URL=postgresql+asyncpg://im_user:im_password@postgres:5432/im_assistant
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

ADMIN_API_TOKEN=change-me
JWT_SECRET_KEY=change-me-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=


AI_ENABLED=false
LITELLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=

# Restricted pi Agent post-processing (enabled by default; requires a valid provider key)
PI_AGENT_ENABLED=true
PI_AGENT_PROVIDER=openai
PI_AGENT_MODEL=gpt-4o-mini
# Falls back to OPENAI_API_KEY only when PI_AGENT_PROVIDER=openai.
PI_AGENT_API_KEY=
PI_AGENT_NODE_BINARY=node
PI_AGENT_RUNNER_PATH=/app/pi-agent-runtime/src/index.mjs
PI_AGENT_TIMEOUT_SECONDS=60
PI_AGENT_MIN_OPPORTUNITY_CONFIDENCE=0.75
PI_AGENT_MAX_LINKS=5
PI_AGENT_LINK_TIMEOUT_SECONDS=10
PI_AGENT_MAX_CONTENT_BYTES=200000
PI_AGENT_MAX_LINK_TEXT_CHARS=12000

# Required only when deploying the cloudflared service locally.
CLOUDFLARE_TUNNEL_TOKEN=
