# Local development defaults. Production .env is generated by GitHub Actions
# from repository/environment vars and secrets.
DATABASE_URL=postgresql+asyncpg://im_user:im_password@postgres:5432/im_assistant
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

ADMIN_API_TOKEN=change-me
JWT_SECRET_KEY=change-me-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Device refresh bearer lifetime and active-device ceiling per user. Bearers are
# returned once; PostgreSQL stores only their SHA-256 hash.
DEVICE_REFRESH_TOKEN_DAYS=30
DEVICE_MAX_ACTIVE_PER_USER=20
# Owner-scoped change feed window and signed bootstrap continuation lifetime.
SYNC_CHANGE_RETENTION_DAYS=30
SYNC_BOOTSTRAP_TOKEN_MINUTES=60
RN_SYNC_ROLLOUT_ENABLED=false
# P4 device analysis claim/gateway remains fail-closed until the Hermes/provider gates pass.
RN_DEVICE_AGENT_ROLLOUT_ENABLED=false
RN_DEVICE_AGENT_ROLLOUT_PERCENTAGE=0
# Cursor-only native push is a separate fail-closed gate. Both rollout flags and
# one fully configured platform provider are required before capability becomes true.
RN_PUSH_ROLLOUT_ENABLED=false
PUSH_DISPATCH_ENABLED=false
PUSH_DISPATCH_INTERVAL_SECONDS=15
PUSH_DISPATCH_BATCH_SIZE=100
PUSH_DISPATCH_LEASE_SECONDS=120
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
# Production and development bundle topics are distinct.
APNS_TOPIC=com.codeiy.im
APNS_SANDBOX_TOPIC=com.codeiy.im.dev
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
PASSWORD_LOGIN_MAX_ATTEMPTS=5
PASSWORD_LOGIN_WINDOW_SECONDS=300
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TTL_MINUTES=15
PASSWORD_RESET_MAX_ATTEMPTS=5
PASSWORD_RESET_REQUEST_LIMIT=3
PASSWORD_RESET_REQUEST_WINDOW_SECONDS=900
PASSWORD_RESET_VERIFY_LIMIT=10
PASSWORD_RESET_VERIFY_WINDOW_SECONDS=900
# Resend SMTP. Use a Resend API key as SMTP_PASSWORD after story2u.xyz is verified.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USERNAME=resend
SMTP_PASSWORD=
SMTP_FROM_EMAIL=dev@story2u.xyz
SMTP_FROM_NAME=商机雷达
SMTP_STARTTLS=false
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=10
FRONTEND_BASE_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
# 移动端原生登录允许的 id_token audience（逗号分隔）；为空 = 原生登录关闭。
# Google 填 iOS OAuth client id（如有 server client id 一并列出），Apple 填 app bundle id。
# Apple 默认已是 iOS app 的 bundle id（com.codeiy.im），一般无需覆盖。
GOOGLE_NATIVE_CLIENT_IDS=
APPLE_NATIVE_CLIENT_IDS=com.codeiy.im

# Telegram native connections. In production, the release workflow generates and persists
# TELEGRAM_WEBHOOK_SECRET; docker-compose.prod.yml supplies the live URL/mode/TTL defaults.
# This local example intentionally keeps mock mode to avoid calling Telegram accidentally.
IM_SEND_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_INTEGRATION_MODE=mock
TELEGRAM_CONNECT_TTL_SECONDS=600
# P2 needs a separate long-lived QR worker. Keep disabled until that worker is deployed.
TELEGRAM_MTPROTO_QR_ENABLED=false
TELEGRAM_MTPROTO_QR_WORKER_ENABLED=false
TELEGRAM_MTPROTO_API_ID=
TELEGRAM_MTPROTO_API_HASH=

# User-owned WeCom internal app connections. Credentials are entered in the UI and encrypted in PostgreSQL.
WECOM_CONNECTION_LIMIT=1
WECOM_WEBHOOK_TOLERANCE_SECONDS=300
WECOM_WEBHOOK_MAX_BODY_BYTES=256000

# Enterprise conversation archive. Requires a paid WeCom archive account and the official
# Linux Finance SDK mounted read-only at WECOM_ARCHIVE_SDK_PATH. Keep disabled until then.
WECOM_ARCHIVE_ENABLED=false
WECOM_ARCHIVE_SDK_PATH=/opt/wecom-finance-sdk/libWeWorkFinanceSdk_C.so
WECOM_ARCHIVE_SDK_DIR=./vendor/wecom-finance-sdk
WECOM_ARCHIVE_POLL_INTERVAL_SECONDS=10
WECOM_ARCHIVE_BATCH_SIZE=100
WECOM_ARCHIVE_SDK_TIMEOUT_SECONDS=5
WECOM_ARCHIVE_LEASE_SECONDS=120
WECOM_ARCHIVE_CONNECTION_LIMIT=1
WECOM_ARCHIVE_SYNC_RATE_LIMIT_SECONDS=30

AI_ENABLED=true
LITELLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=
AI_AUTO_REPLY_ENABLED=true
AI_AUTO_REPLY_MIN_CONFIDENCE=0.85
AI_AUTO_REPLY_COOLDOWN_MINUTES=720
AI_AUTO_REPLY_WINDOW_HOURS=24
AI_AUTO_REPLY_MAX_PER_WINDOW=1
AI_AUTO_REPLY_MAX_CHARS=240
DEEPSEEK_API_KEY=

# Restricted pi Agent post-processing (enabled by default; requires a valid provider key)
PI_AGENT_ENABLED=true
PI_AGENT_PROVIDER=openai
PI_AGENT_MODEL=gpt-4o-mini
# Falls back to OPENAI_API_KEY only when PI_AGENT_PROVIDER=openai.
PI_AGENT_API_KEY=
PI_AGENT_NODE_BINARY=node
PI_AGENT_RUNNER_PATH=/app/pi-agent-runtime/src/index.mjs
PI_AGENT_TIMEOUT_SECONDS=60
PI_AGENT_MIN_OPPORTUNITY_CONFIDENCE=0.75
PI_AGENT_MAX_LINKS=5
PI_AGENT_LINK_TIMEOUT_SECONDS=10
PI_AGENT_MAX_CONTENT_BYTES=200000
PI_AGENT_MAX_LINK_TEXT_CHARS=12000
DEVICE_AGENT_LEASE_SECONDS=120
DEVICE_AGENT_RUN_TOKEN_MINUTES=10
DEVICE_AGENT_SCHEMA_VERSION=1
DEVICE_AGENT_RUNTIME_VERSION=pi-0.80.6
DEVICE_AGENT_MODEL_ALIAS=radar-analysis-v1
DEVICE_AGENT_POLICY_VERSION=agent-policy-v1
DEVICE_AGENT_SHADOW_ENABLED=false
DEVICE_AGENT_FALLBACK_ENABLED=false
DEVICE_AGENT_SHADOW_LOOKBACK_HOURS=24
DEVICE_AGENT_ROLLOUT_ALLOWLIST=
DEVICE_AGENT_ROLLOUT_REQUIRE_SHADOW_READY=true
DEVICE_AGENT_ROLLOUT_LOOKBACK_HOURS=24
DEVICE_AGENT_ROLLOUT_MIN_SHADOW_SAMPLES=50
DEVICE_AGENT_ROLLOUT_MIN_SHADOW_SUCCESS_RATE=0.95
DEVICE_AGENT_ROLLOUT_MIN_SHADOW_MATCH_RATE=0.95
DEVICE_AGENT_ROLLOUT_MAX_P95_SECONDS=120
DEVICE_AGENT_RECENT_DEVICE_MINUTES=15
DEVICE_AGENT_PRIMARY_CLAIM_WINDOW_SECONDS=90
DEVICE_AGENT_EXPIRE_INTERVAL_SECONDS=30
DEVICE_AGENT_EXPIRE_BATCH_SIZE=100
# OpenAI-compatible device inference gateway. Keep disabled until the provider and RN runtime gates pass.
DEVICE_AGENT_GATEWAY_ENABLED=false
DEVICE_AGENT_GATEWAY_PROVIDER=openai
DEVICE_AGENT_GATEWAY_BASE_URL=https://api.openai.com/v1
DEVICE_AGENT_GATEWAY_API_KEY=
DEVICE_AGENT_GATEWAY_MODEL=gpt-4o-mini
DEVICE_AGENT_GATEWAY_TIMEOUT_SECONDS=60
DEVICE_AGENT_GATEWAY_CONNECT_TIMEOUT_SECONDS=10
DEVICE_AGENT_GATEWAY_MAX_REQUEST_BYTES=64000
DEVICE_AGENT_GATEWAY_MAX_PROMPT_CHARS=32000
DEVICE_AGENT_GATEWAY_MAX_OUTPUT_BYTES=1000000
DEVICE_AGENT_GATEWAY_MAX_COMPLETION_TOKENS=4096
DEVICE_AGENT_GATEWAY_MAX_REQUESTS_PER_RUN=3
# Integer micro-currency units per one million tokens; zero records usage without estimating cost.
DEVICE_AGENT_GATEWAY_INPUT_COST_MICROS_PER_MILLION=0
DEVICE_AGENT_GATEWAY_OUTPUT_COST_MICROS_PER_MILLION=0

# Internal interactive Agent beta. Both switches default closed; the beta also requires a
# positive independent turn quota and an explicit device UUID allowlist. Production defaults
# stay on the reviewed v1 pair below. v3 additionally requires external actions and IM sending.
INTERACTIVE_AGENT_BETA_ENABLED=false
INTERACTIVE_AGENT_GATEWAY_ENABLED=false
INTERACTIVE_AGENT_EXTERNAL_ACTIONS_ENABLED=false
INTERACTIVE_AGENT_BETA_MONTHLY_TURN_LIMIT=0
INTERACTIVE_AGENT_DEVICE_ALLOWLIST=
INTERACTIVE_AGENT_LEASE_SECONDS=300
INTERACTIVE_AGENT_TURN_TOKEN_MINUTES=15
INTERACTIVE_AGENT_APPROVAL_TOKEN_SECONDS=120
INTERACTIVE_AGENT_MAX_APPROVALS_PER_TURN=8
INTERACTIVE_AGENT_SCHEMA_VERSION=1
INTERACTIVE_AGENT_RUNTIME_VERSION=pi-0.80.6
INTERACTIVE_AGENT_MODEL_ALIAS=radar-interactive-v1
INTERACTIVE_AGENT_POLICY_VERSION=interactive-read-only-v1
INTERACTIVE_AGENT_GATEWAY_MAX_REQUEST_BYTES=128000
INTERACTIVE_AGENT_GATEWAY_MAX_PROMPT_CHARS=64000
INTERACTIVE_AGENT_GATEWAY_MAX_OUTPUT_BYTES=1000000
INTERACTIVE_AGENT_GATEWAY_MAX_COMPLETION_TOKENS=4096
INTERACTIVE_AGENT_GATEWAY_MAX_REQUESTS_PER_TURN=8
INTERACTIVE_AGENT_EXPIRE_INTERVAL_SECONDS=30
INTERACTIVE_AGENT_EXPIRE_BATCH_SIZE=100

# Unified subscriptions. Disabled by default; no mock entitlement is used in production.
REVENUECAT_ENABLED=true
REVENUECAT_SECRET_API_KEY=
REVENUECAT_PROJECT_ID=
REVENUECAT_WEBHOOK_AUTH_TOKEN=
REVENUECAT_WEBHOOK_HMAC_SECRET=
REVENUECAT_WEBHOOK_TOLERANCE_SECONDS=300
REVENUECAT_SYNC_TIMEOUT_SECONDS=10
REVENUECAT_SYNC_RATE_LIMIT_SECONDS=30
REVENUECAT_RECONCILE_ENABLED=true
REVENUECAT_RECONCILE_INTERVAL_HOURS=24
REVENUECAT_RECONCILE_BATCH_SIZE=100
REVENUECAT_ENTITLEMENT_PLUS=plus
REVENUECAT_ENTITLEMENT_PRO=pro
REVENUECAT_ENTITLEMENT_MAX=max

# Required only when deploying the cloudflared service locally.
CLOUDFLARE_TUNNEL_TOKEN=
