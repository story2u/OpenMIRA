APP_ENV=local
APP_NAME=Opportunity IM Assistant API
DEBUG=true

DATABASE_URL=postgresql+asyncpg://im_user:im_password@postgres:5432/im_assistant
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

ADMIN_API_TOKEN=change-me
CORS_ORIGINS=["https://im.story2u.xyz","http://localhost:3000","http://127.0.0.1:3000"]

DEFAULT_TIMEZONE=Asia/Shanghai
DEFAULT_WORKDAYS=[1,2,3,4,5]
DEFAULT_WORK_START=09:00
DEFAULT_WORK_END=18:30
PENDING_HUMAN_SLA_MINUTES=30

IM_SEND_ENABLED=false
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_WEBHOOK_SECRET=change-me

# Telegram user-client mode. Use this when you are a normal group member and cannot add a bot.
TELEGRAM_USER_ENABLED=false
TELEGRAM_USER_API_ID=0
TELEGRAM_USER_API_HASH=change-me
TELEGRAM_USER_SESSION=
TELEGRAM_USER_CHATS=[]
TELEGRAM_USER_BACKFILL_LIMIT=30

WECOM_CORP_ID=change-me
WECOM_AGENT_ID=1000001
WECOM_SECRET=change-me
WECOM_TOKEN=change-me
WECOM_AES_KEY=change-me

AI_ENABLED=false
LITELLM_MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=change-me

# Required only when deploying the cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=change-me
