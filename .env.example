# Minimal VPS_ENV_FILE template.
# Copy this content into the GitHub Secret named VPS_ENV_FILE, then replace the
# placeholder values before deploying.

# Required for all database-backed API/worker roles.
CLOUD_DB_DSN=postgres://im_user:change-me@postgres.example.com:5432/im?sslmode=require

# Required before exposing API/session routes.
SESSION_JWT_SECRET=change-me-generate-a-long-random-secret

# Required to enable the WeCom/connector notify callback route:
#   /api/v1/notify/event/{enterprise_id}
GO_ENABLE_CONNECTOR_NOTIFY_CALLBACK_CANDIDATE=1
