{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://im-go/contracts/v1/task-create.schema.json",
  "title": "TaskCreate",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "source", "target", "task_type", "payload", "created_at"],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 8
    },
    "source": {
      "type": "string",
      "enum": ["cloud-web", "cloud-backend", "system"]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_id", "device_id"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "device_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "task_type": {
      "type": "string",
      "enum": [
        "send_text",
        "send_image",
        "send_video",
        "send_voice",
        "send_file",
        "group_invite",
        "appointment_billing",
        "send_address",
        "request_money",
        "transfer_money",
        "rpa_voice_call",
        "rpa_video_call",
        "rpa_hangup_call",
        "rpa_prepare_call_audio_output",
        "wework_voice_call",
        "wework_video_call",
        "wework_hangup_call",
        "wework_prepare_call_audio_output",
        "send_mixed_messages",
        "share_bundle_send",
        "revoke_text_message",
        "cancel_message",
        "connector_login_qrcode",
        "connector_login_status",
        "connector_login_verify",
        "connector_user_info",
        "connector_logout",
        "wework_login_qrcode",
        "wework_login_status",
        "wework_login_verify",
        "wework_user_info",
        "wework_logout",
        "logout",
        "device_open_app",
        "device_stop_app",
        "device_screenshot"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["username"],
      "properties": {
        "username": {
          "type": "string",
          "minLength": 1
        },
        "receiver": {
          "type": "string",
          "minLength": 1
        },
        "receivers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "receiver_name": {
          "type": "string"
        },
        "conversation_id": {
          "type": "string",
          "minLength": 1
        },
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "sender_id": {
          "type": "string",
          "minLength": 1
        },
        "customer_relation_status_at_send": {
          "type": "string"
        },
        "customer_deleted_current_member_at_send": {
          "type": "boolean"
        },
        "customer_relation_deleted_at": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "customer_relation_restored_at": {
          "anyOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "text": {
          "type": "string"
        },
        "media_url": {
          "type": "string",
          "format": "uri"
        },
        "media_mime": {
          "type": "string"
        },
        "voice_duration_sec": {
          "type": "integer",
          "minimum": 0,
          "maximum": 60
        },
        "file": {
          "type": "string",
          "format": "uri"
        },
        "filename": {
          "type": "string",
          "minLength": 1
        },
        "group_name": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "string"
        },
        "entity": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" }
          ]
        },
        "msg_id": {
          "type": "string",
          "minLength": 1
        },
        "order_id": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" }
          ]
        },
        "stage_unique_id": {
          "type": "string"
        },
        "remark": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "store_name": {
          "type": "string"
        },
        "store_id": {
          "anyOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "integer" }
          ]
        },
        "tencent_map_store": {
          "type": "string"
        },
        "button_name": {
          "type": "string"
        },
        "money": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "target_trace_id": {
          "type": "string",
          "minLength": 1
        },
        "target_content": {
          "type": "string"
        },
        "target_msg_type": {
          "type": "string",
          "enum": ["text", "image", "video"]
        },
        "target_direction": {
          "type": "string",
          "enum": ["outgoing", ""]
        },
        "occurrence_from_bottom": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        },
        "call_type": {
          "type": "string",
          "enum": ["voice", "video", ""]
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "content"],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "content": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "summary": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              },
              "image": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "username": {
                "type": "string"
              },
              "lat": {
                "type": "number"
              },
              "lng": {
                "type": "number"
              },
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              },
              "filename": {
                "type": "string",
                "minLength": 1
              },
              "address": {
                "type": "string",
                "minLength": 1
              },
              "store_name": {
                "type": "string",
                "minLength": 1
              },
              "store_id": {
                "anyOf": [
                  { "type": "string" },
                  { "type": "number" },
                  { "type": "integer" }
                ]
              },
              "tencent_map_store": {
                "type": "string",
                "minLength": 1
              },
              "button_name": {
                "type": "string",
                "minLength": 1
              },
              "money": {
                "type": "string",
                "minLength": 1
              },
              "note": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string",
                "minLength": 1
              },
              "stage_unique_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "queue": {
          "type": "string",
          "enum": ["fast", "slow"]
        },
        "subprocess_timeout_sec": {
          "type": "integer",
          "minimum": 3
        },
        "no_progress_timeout_sec": {
          "type": "integer",
          "minimum": 3
        },
        "batch_id": {
          "type": "string",
          "minLength": 1
        },
        "client_batch_id": {
          "type": "string",
          "minLength": 1
        },
        "batch_index": {
          "type": "integer",
          "minimum": 0
        },
        "batch_total": {
          "type": "integer",
          "minimum": 1
        },
        "client_batch_index": {
          "type": "integer",
          "minimum": 0
        },
        "client_batch_total": {
          "type": "integer",
          "minimum": 1
        },
        "preserve_individual_send": {
          "type": "boolean"
        },
        "share_mode": {
          "type": "string",
          "enum": ["multi", "merged", "single", "single_loop", ""]
        },
        "ww_app_id": {
          "type": "string"
        },
        "ww_agent_id": {
          "type": "string"
        },
        "ww_schema": {
          "type": "string"
        },
        "share_app_name": {
          "type": "string"
        },
        "timeout_sec": {
          "type": "number",
          "minimum": 1
        },
        "_send_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["origin"],
          "properties": {
            "origin": {
              "type": "string",
              "enum": ["ai_auto_reply", "sop"]
            },
            "source_enabled": {
              "type": "boolean"
            },
            "conversation_id": {
              "type": "string",
              "minLength": 1
            },
            "flow_id": {
              "type": "string",
              "minLength": 1
            },
            "trigger_event": {
              "type": "string",
              "minLength": 1
            },
            "disabled_reason": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          }
        },
        "verify_code": {
          "type": "string"
        },
        "package_name": {
          "type": "string",
          "minLength": 1
        },
        "pkg": {
          "type": "string",
          "minLength": 1
        },
        "sop_audit": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source": {
              "type": "string",
              "minLength": 1
            },
            "flow_id": {
              "type": "string",
              "minLength": 1
            },
            "trigger_event": {
              "type": "string",
              "minLength": 1
            },
            "assignee_id": {
              "type": "string"
            },
            "assignee_name": {
              "type": "string"
            },
            "conversation_id": {
              "type": "string",
              "minLength": 1
            },
            "ai_trace_id": {
              "type": "string"
            },
            "stage_unique_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "flow_name": {
              "type": "string"
            },
            "day_stage": {
              "type": "string"
            },
            "customer_state": {
              "type": "string"
            },
            "stage_tag": {
              "type": "string"
            },
            "task_id": {
              "type": "string"
            },
            "original_task_id": {
              "type": "string"
            },
            "auto_resend_attempt": {
              "type": "integer",
              "minimum": 1
            },
            "auto_resend_reason": {
              "type": "string"
            },
            "auto_resend_original_error": {
              "type": "string"
            }
          }
        },
        "stage_unique_id": {
          "type": "string",
          "minLength": 1
        },
        "verify_type": {
          "type": "string"
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "include_qrcode": {
          "type": "boolean"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trace_id": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "task_type": { "const": "send_text" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "text"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "enum": ["send_image", "send_video"] }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "media_url"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "send_file" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "group_invite" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "group_name"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "appointment_billing" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "msg_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "send_address" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "address", "button_name", "msg_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "request_money" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "money", "msg_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "transfer_money" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "msg_id", "note"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "send_voice" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "media_url"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "enum": ["rpa_voice_call", "rpa_video_call", "wework_voice_call", "wework_video_call"] }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "call_type"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "enum": ["rpa_hangup_call", "wework_hangup_call"] }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "enum": ["rpa_prepare_call_audio_output", "wework_prepare_call_audio_output"] }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "send_mixed_messages" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "msg_id", "messages"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "share_bundle_send" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "msg_id", "messages", "share_mode"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "revoke_text_message" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "target_trace_id", "target_content", "target_msg_type", "occurrence_from_bottom"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "const": "cancel_message" }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "receiver", "entity", "msg_id"]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task_type": { "enum": ["connector_login_verify", "wework_login_verify"] }
        }
      },
      "then": {
        "properties": {
          "payload": {
            "required": ["username", "verify_code", "verify_type"]
          }
        }
      }
    }
  ]
}
