# Minimal env for the VPS receive-message stack.
# The compose file already defaults Redis, Postgres, and the notify callback route.

SESSION_JWT_SECRET=change-me-generate-a-long-random-secret
CLOUDFLARE_TUNNEL_TOKEN=change-me-cloudflare-tunnel-token

# Optional: set both when changing the bundled Postgres password.
# POSTGRES_PASSWORD=change-me-postgres-password
# CLOUD_DB_DSN=postgres://im:change-me-postgres-password@go-postgres:5432/im?sslmode=disable
